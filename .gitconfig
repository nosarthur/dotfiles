[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    features = side-by-side line-numbers decorations
    whitespace-error-style = 22 reverse

[delta "decorations"]
    commit-decoration-style = bold yellow box ul
    file-style = bold yellow ul
    file-decoration-style = none

[diff]
	tool = vimdiff
	algorithm = patience
[difftool]
	prompt = false
[merge]
	tool = vimdiff
[core]
	editor = vim
    #pager = diff-so-fancy | less --tabs=4 -RFX
[alias]
	co = checkout
	ci = commit
	br = branch
	st = status
    stat = diff --stat
    dt = difftool
	unstage = reset HEAD --
	last = log --pretty=oneline -3 HEAD
    cram = commit -a --amend --no-edit
    logo = log --pretty=oneline
#[url "git@github.com:"]
#    insteadOf = "https://github.com/"
[user]
	name = Dong Zhou
    #email = dong.zhou@schrodinger.com
    email = zhou.dong@gmail.com
[pull]
	rebase = true
[init]
	defaultBranch = main
[branch]
	autosetupmerge = always
[push]
	default = simple
